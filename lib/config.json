{
    "modules": {
        "grid": "true",
        "flex": "true",
        "utilities": "true"
    },

    "spacing": {
        "unit": "px",
        "base-spacing": "5"
    },

    "colors": {
        "primary-color": "#000",
        "secondary-color": "#000",
        "text-color": "#000",
        "background-color": "#000"
    },

    "typography": {
        "font-family": "Arial, sans-serif",
        "fontSize": {
          "small": "14px",
          "medium": "16px",
          "large": "18px"
        },
        "line-height": {
          "small": 1.5,
          "medium": 1.6,
          "large": 1.7
        }
    },

    "media-queries": {
        "mobile": "(max-width: 768px)",
        "tablet": "(min-width: 769px) and (max-width: 1024px)",
        "desktop": "(min-width: 1025px)"
    }
}